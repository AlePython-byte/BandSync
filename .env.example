# API key de Resend para envío de correos (https://resend.com)
RESEND_API_KEY=re_tu_api_key_aqui

# Secreto para firmar los JWT — cámbialo en producción por uno largo y aleatorio
JWT_SECRET=cambia-este-secret-en-produccion
